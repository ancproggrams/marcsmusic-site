APP_BASE_URL=https://www.marcsmusic.nl
PORT=3000

# Public booking rules
BOOKING_TIMEZONE=Europe/Amsterdam
BOOKING_WORKDAY_START=10:00
BOOKING_WORKDAY_END=22:00
BOOKING_SLOT_STEP_MINUTES=30
BOOKING_MAX_CONSECUTIVE_SLOTS=4
BOOKING_BUFFER_MINUTES=30
BOOKING_MIN_LEAD_HOURS=24
BOOKING_PENDING_HOLD_MINUTES=20

# Prices are in cents
BOOKING_PRICE_STUDIO_CENTS=7500
BOOKING_PRICE_DJ_CENTS=20000
BOOKING_PRICE_OTHER_CENTS=9900
BOOKING_DURATION_STUDIO_MINUTES=60
BOOKING_DURATION_DJ_MINUTES=60
BOOKING_DURATION_OTHER_MINUTES=60
BOOKING_TRAVEL_RATE_CENTS_PER_HOUR=7500
BOOKING_MAX_TRAVEL_HOURS=24

# EspoCRM
ESPOCRM_BASE_URL=https://crm.marcsmusic.nl
ESPOCRM_API_KEY=
ESPOCRM_API_SECRET=
ESPOCRM_USE_CUSTOM_FIELDS=false
CRM_NEWSLETTER_LIST=MarcsMusic Newsletter
NEWSLETTER_FROM_EMAIL=noreply@marcsmusic.nl
NEWSLETTER_FROM_NAME=MarcsMusic
CRM_BOOKING_ENTITY=DJBooking
CRM_SOURCE_WEBSITE=marcsmusic.nl

# Self-hosted calendar, e.g. Radicale
CALDAV_BASE_URL=https://calendar.marcsmusic.nl
CALDAV_USERNAME=
CALDAV_PASSWORD=
CALDAV_CALENDAR_PATH=/marcsmusic/bookings/

# Mollie
MOLLIE_API_KEY=

# Admin page and privacy
ADMIN_TOKEN=change-this-long-random-token
BOOKING_ADMIN_EMAIL=
PRIVACY_HASH_SALT=change-this-random-salt

# Railway persistent volume mounted at /data.
BOOKING_DB_PATH=/data/bookings.json
