{
  "name": "@marcsmusic/music-submission-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Railway-ready discovery, verification, queue and submission worker service for MarcsMusic music outreach.",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "db:init": "tsx src/db/init.ts",
    "run:once": "tsx src/index.ts --once",
    "seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^11.10.0",
    "bullmq": "^5.58.0",
    "cheerio": "^1.0.0",
    "csv-stringify": "^6.5.2",
    "dns2": "^2.1.0",
    "exceljs": "^4.4.0",
    "ioredis": "^5.6.1",
    "nanoid": "^5.1.5",
    "pino": "^9.7.0",
    "undici": "^7.11.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.15.32",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
